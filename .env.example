# 접근 제한 — 비밀번호 하나로 본인만 접속 (OAuth 없음, 배포 용량 절감)
# openssl rand -base64 32 또는 강한 비밀번호 입력
ACCESS_SECRET=

# Google Sheets API
# 로컬: 서비스 계정 JSON 파일 경로
# GOOGLE_APPLICATION_CREDENTIALS=./my-stock-service-account.json
# Vercel: 서비스 계정 JSON 전체 내용을 한 줄로 (Environment Variables에 GOOGLE_SERVICE_ACCOUNT_JSON 로 등록)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# 403 "unregistered callers" 발생 시: 서비스 계정의 프로젝트 ID (keyFile 사용 시에만, 선택)
# GOOGLE_CLOUD_PROJECT=my-gcp-project-id
GOOGLE_SPREADSHEET_ID=
# 시트 탭 이름 (기본: Sheet1, 한국어 계정이면 시트1 로 설정)
GOOGLE_SHEET_NAME=매매내역
# 종목코드 마스터 시트 탭 (미설정 시 사용 안 함). 컬럼: Ticker, Code
GOOGLE_SHEET_TICKER_MASTER=종목코드
# 종목별 집계 시트 탭 (미설정 시 메모리 집계만). 컬럼: Ticker, Code(선택), 매수횟수, 매도횟수, ...
GOOGLE_SHEET_AGGREGATION=종목별집계

# DART 전자공시 Open API (재무제표·비율) — opendart.fss.or.kr 인증키
DART_API_KEY=

# Korea Investment & Securities (KIS) Open API
KIS_APP_KEY=
KIS_APP_SECRET=
# 실전: 기본 URL. 모의투자 시 KIS_APP_SVR=vps 또는 KIS_APP_URL 직접 지정
# KIS_APP_SVR=vps
# KIS_APP_URL=https://openapivts.koreainvestment.com:29443
# 투자의견 API 전용 tr_id (미설정 시 FHKST03110100). KIS 포털 [국내주식] 시세분석에서 확인
# KIS_OPINION_TR_ID=FHKST03110100
# 종목정보(search-info) PER/PBR/EPS용 tr_id (미설정 시 FHKST02010100). "없는 서비스 코드" 시 KIS 포털에서 TR 확인 후 설정
# KIS_SEARCH_INFO_TR_ID=FHKST02010100
# EGW00201(초당 거래건수 초과) 완화: KIS 요청 간 최소 간격(ms). 미설정 시 400(초당 약 2.5건)
# KIS_THROTTLE_MS=400
# OPSQ2001 방지용 필수 입력값(미설정 시 기본값 사용). 재무/비율: FID_DIV_CLS_CODE(0=개별 1=연결), 투자의견: FID_COND_SCR_DIV_CODE(J)·FID_INPUT_DATE_1(기준일), 증권사별투자의견: FID_DIV_CLS_CODE(0), 일별체결량: FID_COND_MRKT_DIV_CODE_1(J)·FID_INPUT_ISCD_1(종목코드), 매매동향: FID_ORG_ADJ_PRC(0)·FID_ETC_CLS_CODE(0), 추정실적: SHT_CD(0)
# KIS_FID_DIV_CLS_CODE=0
# KIS_COND_SCR_DIV_CODE=J
# KIS_OPINION_DIV_CLS_CODE=0
# KIS_ORG_ADJ_PRC=0
# KIS_ETC_CLS_CODE=0
# KIS_ESTIMATE_SHT_CD=0

# Vercel 배포: 서버리스 함수 250MB 초과 원인 분석 (빌드 로그에 함수별 크기·Large dependencies 출력)
# VERCEL_ANALYZE_BUILD_OUTPUT=1
